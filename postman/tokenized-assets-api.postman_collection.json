  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function loadCryptoJS() {",
          "  const root = typeof globalThis !== 'undefined' ? globalThis : typeof global !== 'undefined' ? global : {};",
          "  if (root.CryptoJS) return root.CryptoJS;",
          "  try { return require('crypto-js'); } catch (e) {}",
          "  if (typeof pm !== 'undefined' && typeof pm.require === 'function') {",
          "    try { return pm.require('crypto-js'); } catch (e2) {}",
          "  }",
          "  throw new Error(",
          "    '[HMAC] CryptoJS unavailable. Use Postman Desktop (built-in CryptoJS), or add the npm package crypto-js to this workspace (Package Library) so require/pm.require can load it.'",
          "  );",
          "}",
          "const CryptoJS = loadCryptoJS();",
          "",
          "function randomNonceHex32() {",
          "  const hex = '0123456789abcdef';",
          "  let s = '';",
          "  for (let i = 0; i < 32; i++) s += hex[Math.floor(Math.random() * 16)];",
          "  return s;",
          "}",
          "",
          "function requestPath() {",
          "  if (typeof pm.request.url.getPath === 'function') {",
          "    const p = pm.request.url.getPath();",
          "    if (p && typeof p === 'string') return p.startsWith('/') ? p : '/' + p;",
          "  }",
          "  const segs = pm.request.url.path;",
          "  if (Array.isArray(segs) && segs.length) return '/' + segs.filter(Boolean).join('/');",
          "  const raw = pm.variables.replaceIn(pm.request.url.toString());",
          "  try {",
          "    const u = new URL(raw);",
          "    return u.pathname || '/';",
          "  } catch (e) {",
          "    return '/';",
          "  }",
          "}",
          "",
          "const method = pm.request.method.toUpperCase();",
          "const path = requestPath();",
          "",
          "if (path.startsWith('/v1/health')) {",
          "  ['x-timestamp', 'x-signature', 'x-nonce', 'X-Timestamp', 'X-Signature', 'X-Nonce'].forEach((h) => {",
          "    try { pm.request.headers.remove(h); } catch (e) {}",
          "  });",
          "  return;",
          "}",
          "",
          "const isAdmin = path.startsWith('/v1/admin');",
          "const secretKey = isAdmin ? 'ADMIN_HMAC_SECRET' : 'CLIENT_HMAC_SECRET';",
          "const secret = pm.environment.get(secretKey) || pm.collectionVariables.get(secretKey);",
          "if (!secret) {",
          "  console.warn('[HMAC] Set environment variable ' + secretKey + ' (≥32 chars, match backend .env).');",
          "  return;",
          "}",
          "",
          "const ts = String(Date.now());",
          "let rawBody = '';",
          "try {",
          "  const b = pm.request.body;",
          "  if (b && b.mode === 'raw' && typeof b.raw === 'string') rawBody = b.raw;",
          "} catch (e) {}",
          "",
          "const bodyHash = CryptoJS.SHA256(rawBody).toString(CryptoJS.enc.Hex);",
          "const mutating = ['POST', 'PUT', 'PATCH', 'DELETE'].includes(method);",
          "",
          "let canonical;",
          "let nonce = '';",
          "if (mutating) {",
          "  nonce = randomNonceHex32();",
          "  canonical = [method, path, ts, bodyHash, nonce].join('\\n');",
          "} else {",
          "  canonical = [method, path, ts, bodyHash].join('\\n');",
          "  try { pm.request.headers.remove('X-Nonce'); } catch (e) {}",
          "  try { pm.request.headers.remove('x-nonce'); } catch (e) {}",
          "}",
          "",
          "const sig = CryptoJS.HmacSHA256(canonical, secret).toString(CryptoJS.enc.Hex);",
          "",
          "pm.request.headers.upsert({ key: 'X-Timestamp', value: ts });",
          "pm.request.headers.upsert({ key: 'X-Signature', value: sig });",
          "if (mutating) pm.request.headers.upsert({ key: 'X-Nonce', value: nonce });"
        ]
      }
    }
  ],
